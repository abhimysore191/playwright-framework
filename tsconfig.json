{
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonjs",
        "lib": ["ES2020"],
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "outDir": "./dist",
        "rootDir": "./",
        "baseUrl": ".",
        "ignoreDeprecations": "6.0",
        "paths": {
            "@pages/*": ["src/pages/*"],
            "@fixtures/*": ["src/fixtures/*"],
            "@utils/*": ["src/utils/*"]
        }
    },
    "include": ["**/*.ts"],
    "exclude": ["node_modules", "dist"]
}
